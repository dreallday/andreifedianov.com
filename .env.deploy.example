# Copy this file to `.env.deploy` (gitignored) and fill in your real hosts.
# Used by scripts/deploy.sh via `pnpm deploy` and `pnpm deploy:local`.

DEPLOY_HOST=root@your-tailscale-host        # used by `pnpm deploy`
DEPLOY_HOST_LOCAL=root@your-lan-host         # used by `pnpm deploy:local`
# DEPLOY_PATH=/mnt/user/appdata/nginx-af/www/   # override the webroot if needed
